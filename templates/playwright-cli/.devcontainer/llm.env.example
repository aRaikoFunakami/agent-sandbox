# =============================================================================
# LLM Provider Configuration
# Copy this file to llm.env and uncomment/edit the section you need.
# Only one provider section should be active at a time per tool.
# =============================================================================

# -----------------------------------------------------------------------------
# [Option A] Local LLM via OpenAI-compatible proxy
# Use this when running a local model server (vLLM, llama.cpp, etc.)
# -----------------------------------------------------------------------------

# -- GitHub Copilot CLI --
# COPILOT_PROVIDER_BASE_URL=http://your-server:8000/v1
# COPILOT_PROVIDER_TYPE=openai
# COPILOT_MODEL=Qwen3.5-9B-bf16

# -- Claude Code --
# ANTHROPIC_BASE_URL=http://your-server:8000/
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
# ANTHROPIC_DEFAULT_SONNET_MODEL=default
# ANTHROPIC_DEFAULT_OPUS_MODEL=default
# ANTHROPIC_DEFAULT_HAIKU_MODEL=default
# ANTHROPIC_AUTH_TOKEN=test
# ANTHROPIC_API_KEY=test

# -----------------------------------------------------------------------------
# [Option B] OpenAI API (official)
# -----------------------------------------------------------------------------

# -- GitHub Copilot CLI --
# COPILOT_PROVIDER_BASE_URL=https://api.openai.com/v1
# COPILOT_PROVIDER_TYPE=openai
# COPILOT_MODEL=gpt-4o

# -- For tools that read OPENAI_API_KEY directly --
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# [Option C] Anthropic API (official)
# Use your real Anthropic API key here.
# -----------------------------------------------------------------------------

# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# [Option D] GitHub Copilot (default)
# No environment variables needed. Authenticate with `copilot /login` inside
# the container. This is the default if llm.env is empty or absent.
# -----------------------------------------------------------------------------
